@page "/Error"
@using System.Diagnostics

<PageTitle>Error · SecondBrain RAG</PageTitle>

<section class="empty-state">
    <div>
        <span class="kicker">Error</span>
        <h1 class="mt-3">Ha ocurrido un problema al procesar la solicitud.</h1>
        @if (ShowRequestId)
        {
            <p class="muted">
                Identificador de solicitud: <code>@RequestId</code>
            </p>
        }
        <p class="muted">Esta pantalla mantiene el mismo lenguaje visual de la maqueta y evita mostrar información sensible en producción.</p>
        <a class="btn-sb-primary" href="">Volver al dashboard</a>
    </div>
</section>

@code{
    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    private string? RequestId { get; set; }

    private bool ShowRequestId => !string.IsNullOrEmpty(RequestId);

    protected override void OnInitialized() =>
        RequestId = Activity.Current?.Id ?? HttpContext?.TraceIdentifier;
}
