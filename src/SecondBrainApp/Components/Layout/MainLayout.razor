@inherits LayoutComponentBase

<div class="app-shell">
    <aside class="sidebar" aria-label="Navegación principal">
        <NavMenu/>
    </aside>

    <main class="main-area">
        <header class="topbar">
            <div>
                <p class="eyebrow mb-1">SecondBrain RAG</p>
                <strong>Base de conocimiento local asistida por IA</strong>
            </div>
            <div class="topbar-actions" aria-label="Estado del prototipo">
                <span class="status-pill"><span class="status-dot"></span> UI prototype</span>
                <span class="privacy-pill">Ollama local</span>
            </div>
        </header>

        <article class="content">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    Se ha producido un error inesperado.
    <a href="." class="reload">Recargar</a>
    <span class="dismiss">🗙</span>
</div>
